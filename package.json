{
  "name": "pi-print-automation",
  "private": true,
  "description": "Pi Zero 2W paid print automation service",
  "scripts": {
    "dev:server": "pnpm --filter pi-server dev",
    "dev:frontend": "pnpm --filter frontend dev",
